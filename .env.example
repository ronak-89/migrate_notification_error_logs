# ============================================
# REQUIRED ENVIRONMENT VARIABLES
# ============================================
# Copy to .env and fill in values.
# Same DB as notification_service (Supabase / notification_logs).

# ========== PostgreSQL ==========
DB_HOST=your-db-host.example.com
DB_DATABASE=your-database-name
DB_USER=your-db-username
DB_PASSWORD=your-db-password
DB_PORT=5432

# ========== MongoDB (checkpoint for resumability) ==========
MONGO_URI=mongo_URI
MONGO_DB_NAME=db_name
MONGO_CHECKPOINT_COLLECTION=collection_name

# ============================================
# OPTIONAL
# ============================================
DB_CONNECTION_TIMEOUT=30

# Rows per migration batch (default 50000). Overridable by --batch-size.
BATCH_SIZE=50000
