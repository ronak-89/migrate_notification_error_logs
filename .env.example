# ============================================
# REQUIRED ENVIRONMENT VARIABLES
# ============================================
# Copy to .env and fill in values.
# Same DB as notification_service (Supabase / notification_logs).

# ========== PostgreSQL ==========
DB_HOST=your-db-host.example.com
DB_DATABASE=your-database-name
DB_USER=your-db-username
DB_PASSWORD=your-db-password
DB_PORT=5432

# ========== MongoDB (checkpoint for resumability) ==========
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=Cluster0
MONGO_DB_NAME=checkpoint_db
MONGO_CHECKPOINT_COLLECTION=notification_log_errors_migration

# ============================================
# OPTIONAL
# ============================================
DB_CONNECTION_TIMEOUT=30

# Rows per migration batch (default 50000). Overridable by --batch-size.
BATCH_SIZE=50000
